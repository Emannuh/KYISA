# ─────────────────────────────────────────────────────────────────────────────
# KYISA CMS — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── DJANGO CORE ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite (default, good for development):
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production):
# DATABASE_URL=postgres://kyisa_user:your_password@localhost:5432/kyisa_db

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your frontend URL(s) here
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── EMAIL ─────────────────────────────────────────────────────────────────────
# Development: use console backend (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production (AWS SES SMTP):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.af-south-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-ses-smtp-user
# EMAIL_HOST_PASSWORD=your-ses-smtp-password
# DEFAULT_FROM_EMAIL=KYISA CMS <noreply@kyisa.ke>

# ── CLOUD MEDIA STORAGE ──────────────────────────────────────────────────────
# Set STORAGE_BACKEND to "azure" or "s3" or "gcs". Leave empty for local file storage.
STORAGE_BACKEND=

# Azure Blob Storage (recommended for Azure deployment):
# AZURE_ACCOUNT_NAME=kyisacms
# AZURE_ACCOUNT_KEY=your-storage-account-key
# AZURE_CONTAINER=media

# Google Cloud Storage (for GCP deployment):
# GS_BUCKET_NAME=kyisa-cms-media
# GS_PROJECT_ID=kyisa-cms

# AWS S3 (for AWS deployment):
# AWS_ACCESS_KEY_ID=your-iam-access-key
# AWS_SECRET_ACCESS_KEY=your-iam-secret-key
# AWS_STORAGE_BUCKET_NAME=kyisa-cms-media
# AWS_S3_REGION_NAME=af-south-1

# DigitalOcean Spaces (S3-compatible — use STORAGE_BACKEND=s3):
# AWS_ACCESS_KEY_ID=your-spaces-key
# AWS_SECRET_ACCESS_KEY=your-spaces-secret
# AWS_STORAGE_BUCKET_NAME=kyisa-media
# AWS_S3_REGION_NAME=ams3
# AWS_S3_ENDPOINT_URL=https://ams3.digitaloceanspaces.com
# AWS_S3_CUSTOM_DOMAIN=kyisa-media.ams3.digitaloceanspaces.com
